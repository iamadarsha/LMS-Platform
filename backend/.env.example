# Gemini API key — required for analysis
GEMINI_API_KEY=

# faster-whisper model. Options: tiny, base, small, medium, large-v3
# small is a reasonable default for CPU. Use tiny for fast/low-resource dev.
WHISPER_MODEL=small

# cpu | cuda | auto
WHISPER_DEVICE=auto

# int8 (CPU), int8_float16, float16 (GPU), float32
WHISPER_COMPUTE_TYPE=int8

# Where to store uploads + extracted audio + job metadata.
# Relative paths resolve from the backend/ directory.
STORAGE_DIR=uploads/contributions

# Frontend dev origin for CORS (comma-separated for multiple)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Bind host/port for uvicorn
HOST=127.0.0.1
PORT=8787

# Max upload size (bytes). Default 500 MB to match the frontend cap.
MAX_UPLOAD_BYTES=524288000
