# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase (public feed, watch progress, profiles)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
# Gemini (Google AI Studio → https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Clerk backend keys (https://dashboard.clerk.com → API Keys)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# Neon Postgres (pipeline job store)
DATABASE_URL=postgresql://neondb_owner:...@ep-...neon.tech/neondb?sslmode=require

# Upstash Redis (status caching, rate limiting)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
REDIS_URL=rediss://default:...@...upstash.io:6380

# Cloudflare R2 (video storage)
R2_ACCOUNT_ID=...
R2_BUCKET=hyvemind-videos
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_API_TOKEN=...            # cfat_ token (REST fallback)
R2_ACCESS_KEY_ID=...        # S3-compatible access key (32 chars)
R2_SECRET_ACCESS_KEY=...    # S3-compatible secret key

# ─── Optional overrides ───────────────────────────────────────────────────────
WHISPER_MODEL=small          # tiny | base | small | medium | large-v3
WHISPER_DEVICE=auto          # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=int8    # int8 | float16 | float32
MAX_UPLOAD_BYTES=524288000   # 500 MB default
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
STORAGE_DIR=uploads/contributions
