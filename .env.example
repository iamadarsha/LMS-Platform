# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  Hyvemind — environment variables                                          ║
# ║                                                                            ║
# ║  Copy this file to `.env` and fill in your real values:                    ║
# ║      cp .env.example .env                                                  ║
# ║                                                                            ║
# ║  Each section below explains where to get the credential and links to     ║
# ║  the dashboard/docs you need.                                              ║
# ╚════════════════════════════════════════════════════════════════════════════╝


# ──────────────────────────────────────────────────────────────────────────────
# CLERK (authentication — sign-in, OAuth, sessions)
#   Dashboard: https://dashboard.clerk.com
#   Settings → API Keys
# ──────────────────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_PUBLISHABLE_KEY"
CLERK_PUBLISHABLE_KEY="pk_test_YOUR_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_YOUR_SECRET_KEY"
# These two are derived from your Clerk Frontend API URL — find it under
# Dashboard → Settings → API Keys → "Frontend API"
CLERK_ISSUER="https://YOUR-DOMAIN.clerk.accounts.dev"
CLERK_JWKS_URL="https://YOUR-DOMAIN.clerk.accounts.dev/.well-known/jwks.json"


# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE (public content feed, watch progress, profiles)
#   Dashboard: https://supabase.com/dashboard
#   Settings → API
# ──────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ_YOUR_ANON_PUBLIC_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"
# Optional — only needed if you run scripts/apply-migrations.sh
SUPABASE_SERVICE_ROLE_KEY="eyJ_YOUR_SERVICE_ROLE_KEY"
SUPABASE_PAT="sbp_YOUR_PERSONAL_ACCESS_TOKEN"


# ──────────────────────────────────────────────────────────────────────────────
# GEMINI (AI analysis + Whisper fallback transcription)
#   Get key: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY="AIza_YOUR_GEMINI_KEY"


# ──────────────────────────────────────────────────────────────────────────────
# NEON POSTGRES (private pipeline job state — per-user)
#   Dashboard: https://console.neon.tech
#   Project → Connection Details → "Pooled connection"
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.aws.neon.tech/neondb?sslmode=require&channel_binding=require"


# ──────────────────────────────────────────────────────────────────────────────
# UPSTASH REDIS (status caching + rate limiting)
#   Dashboard: https://console.upstash.com
#   Database → REST API
# ──────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR-REGION.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_REST_TOKEN"
REDIS_URL="rediss://default:YOUR_TOKEN@YOUR-REGION.upstash.io:6379"


# ──────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE R2 (video + audio storage — primary)
#   Dashboard: https://dash.cloudflare.com → R2
#   "Manage R2 API Tokens" → create a token with read/write to your bucket
# ──────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID="YOUR_R2_ACCOUNT_ID"
R2_BUCKET="hyvemind-videos"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# S3-compatible credentials (preferred — uses boto3 native path)
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
# Optional — used as REST fallback only when S3 keys aren't set
R2_API_TOKEN="cfat_YOUR_REST_TOKEN"


# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL OVERRIDES (sensible defaults already applied)
# ──────────────────────────────────────────────────────────────────────────────
# WHISPER_MODEL=small             # tiny | base | small | medium | large-v3
# WHISPER_BEAM_SIZE=5              # 1 = greedy (fast), 5 = beam search (quality)
# WHISPER_DEVICE=auto              # auto | cpu | cuda
# WHISPER_COMPUTE_TYPE=int8        # int8 | float16 | float32
# MAX_UPLOAD_BYTES=524288000       # 500 MB default
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# STORAGE_DIR=uploads/contributions
